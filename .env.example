# ─── Supabase ────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Service Role Key (server-side only — Netlify functions, never expose to client)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Subscription plans (Stripe Price IDs)
VITE_STRIPE_SOLO_PRICE_ID=price_...
VITE_STRIPE_GROWTH_PRICE_ID=price_...

# One-time credit pack Payment Links (buy.stripe.com/...)
VITE_STRIPE_CREDITS_20=https://buy.stripe.com/...
VITE_STRIPE_CREDITS_50=https://buy.stripe.com/...
VITE_STRIPE_CREDITS_120=https://buy.stripe.com/...

# Stripe server-side (Netlify functions)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Google OAuth ─────────────────────────────────────────────────────────────
VITE_GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com

# ─── Newsletter (optional) ────────────────────────────────────────────────────
# Mailchimp (leave empty to skip Mailchimp sync — Supabase DB is always used)
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=

# ─── Resend (transactional email) ────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM=noreply@bitbrew.pl
